# DevPulse Backend Environment Configuration
# Copy this file to .env and fill in your values

# Required: Groq API key for AI-powered code generation
# Get your key at: https://console.groq.com/
GROQ_API_KEY=your_groq_key_here

# Server configuration
PORT=8000
HOST=0.0.0.0

# Environment: development | production | test
ENV=development

# Logging level: debug | info | warning | error
LOG_LEVEL=info

# ── Database (PostgreSQL) ────────────────────────────────────
# When unset, falls back to SQLite (devpulse.db) for local dev.
# Production: postgresql+asyncpg://user:pass@host:5432/devpulse
DATABASE_URL=
# Connection pool settings (only relevant for PostgreSQL)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=20

# ── Redis ────────────────────────────────────────────────────
# When unset, the app uses an in-memory LRU cache fallback.
# Example: redis://localhost:6379/0
REDIS_URL=

# JWT auth
JWT_SECRET=devpulse-secret-key-change-in-production
JWT_EXPIRY_HOURS=24

# Stripe Billing (optional – runs in stub mode without these)
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_PRO_MONTHLY=price_xxx
STRIPE_PRICE_PRO_YEARLY=price_xxx
STRIPE_PRICE_ENT_MONTHLY=price_xxx
STRIPE_PRICE_ENT_YEARLY=price_xxx

# SendGrid Email (optional – runs in stub mode without)
SENDGRID_API_KEY=
FROM_EMAIL=hello@devpulse.dev
FROM_NAME=DevPulse

# PostHog Analytics (optional)
POSTHOG_API_KEY=
POSTHOG_HOST=https://app.posthog.com

# Sentry Error Tracking (optional)
SENTRY_DSN=

# Frontend URL (for email links and CORS)
FRONTEND_URL=http://localhost:3000
